{
  "name": "@agentmeter/cli",
  "version": "0.4.3",
  "description": "Track local AI coding agent session costs — Claude Code, Cursor, Codex",
  "keywords": [
    "ai",
    "agent",
    "cost",
    "tracking",
    "claude-code",
    "cursor",
    "token",
    "observability"
  ],
  "license": "MIT",
  "author": "Adam Henson",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentMeter/sdk"
  },
  "homepage": "https://agentmeter.app",
  "engines": {
    "node": ">=22.5.0"
  },
  "type": "module",
  "bin": {
    "agentmeter": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
